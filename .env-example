# ==================================
# ASLIN 2.0 - Configuracion General
# ==================================

# BACKEND
SECRET_KEY=REEMPLAZAR_POR_SECRETO_LARGO_Y_UNICO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
# development | production — en production se ocultan /docs y /redoc
ENVIRONMENT=development

# FRONTEND (prod: https://app.aslin.online)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LfuXBIsAAAAAHBe_Pm_l4qF24tMLfBw3OwtDX3W


# Postgres (usado por docker-compose)
# IMPORTANTE: DATABASE_URL debe usar el MISMO usuario y contraseña que POSTGRES_*
POSTGRES_USER=root
POSTGRES_PASSWORD=TU_PASSWORD_SEGURO
POSTGRES_DB=aslin_mx_v2

# Backend FastAPI - host "db" = nombre del servicio en docker-compose
# USUARIO y PASSWORD deben coincidir con POSTGRES_USER y POSTGRES_PASSWORD
DATABASE_URL=postgresql://root:TU_PASSWORD_SEGURO@db:5432/aslin_mx_v2
SECRET_KEY=REEMPLAZAR_POR_SECRETO_LARGO_Y_UNICO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# reCAPTCHA Enterprise v3
GOOGLE_CLOUD_PROJECT_ID=asicom-441602
RECAPTCHA_KEY=6LfuXBIsAAAAAHBe_Pm_l4qF24tMLfBw3OwtDX3W
RECAPTCHA_SITE_KEY=6LfuXBIsAAAAAHBe_Pm_l4qF24tMLfBw3OwtDX3W

# CORS - IMPORTANTE: usar arreglo JSON para evitar el JSONDecodeError
# Desarrollo: ["http://localhost:3000","http://frontend:3000"]
# Producción: incluir https://aslin.online (frontend)
CORS_ORIGINS=["http://localhost:3000","http://frontend:3000","https://aslin.online","http://aslin.online"]

# Puertos expuestos por docker-compose
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Storage
# local: guarda archivos en disco
# r2: guarda archivos en Cloudflare R2
# auto: usa R2 si encuentra credenciales completas; si no, cae a local
LEGACY_DOCUMENTS_ROOT=
UPLOAD_DIR=uploads
STORAGE_LOCAL_ROOT=

# Cloudflare R2
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_VALIDATE_ON_STARTUP=true

